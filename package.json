{
  "name": "todo-qa-automation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf allure-results/* allure-report/*",
    "pretest": "npm run clean",
    "test": "playwright test || true",
    "posttest": "npm run report:generate && npm run report:open",
    "report:generate": "npx allure generate allure-results --clean -o allure-report",
    "report:open": "npx allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1"
  }
}
