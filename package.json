{
  "name": "todo-qa-automation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean:results": "shx rm -rf allure-results",
    "pretest": "npm run clean:results",
    "test": "playwright test --project=chromium --workers=1 || true",
    "posttest": "npm run preallure:generate && npm run report:generate && npm run report:open",
    "preallure:generate": "shx mkdir -p allure-results/history && shx cp -r allure-report/history/* allure-results/history || true",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "shx": "^0.4.0"
  }
}
